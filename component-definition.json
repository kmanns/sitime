          "plugins": {
            "da": {
              "type": "key-value-block",
              "unsafeHTML": "<div class=\"circle-carousel\"><div><div>alignment</div><div>center</div></div><div><div>autoplay</div><div>true</div></div><div><div>items-desktop</div><div>6</div></div></div>"
            }
