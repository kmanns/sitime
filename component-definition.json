          "model": "hero-cta",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 1,
              "unsafeHTML": "<div class=\"hero-cta\"><div><div><picture><img src=\"\" alt=\"Hero background image\"></picture></div><div><h1>Hero Headline</h1><p>Supporting subtitle or description.</p><p><a href=\"/page\">Primary CTA</a></p><p><a href=\"/page2\">Secondary CTA</a></p></div></div><div><div>herocta-height</div><div>tall</div></div><div><div>herocta-cta-anchor</div><div>bottom-left</div></div><div><div>interval</div><div>5000</div></div></div>"
            }
          }
        },
