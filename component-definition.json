          "model": "newsletter",
          "plugins": {
            "da": {
              "type": "key-value-block",
              "unsafeHTML": "<div class=\"newsletter\"><div><div>align</div><div>center</div></div><div><div>background</div><div>neutral</div></div><div><div>Sign up for updates</div></div><div><div>Get the latest news and offers.</div></div><div><div>Your email address</div></div><div><div>Subscribe</div></div><div><div>By subscribing you agree to our <a href=\"/privacy\">Privacy Policy</a>.</div></div><div><div>You're subscribed!</div></div><div><div>Thanks for signing up. Check your inbox for a confirmation.</div></div></div>"
            }
          }
        },
