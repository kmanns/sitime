          }
        },
        {
          "title": "Blog Tiles",
          "id": "blog-tiles",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"blog-tiles\"><div><div>blogtiles-limit</div><div>24</div></div><div><div>blogtiles-sort</div><div>newest</div></div><div><div>blogtiles-showdescription</div><div>true</div></div></div>"
            }
          }
        },
        {
          "title": "Cards List",
          "id": "cards-list",
          "plugins": {
            "da": {
              "rows": 1,
