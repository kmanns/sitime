# ─── Step 1: Copy from Acrobat Sign > Home > Web Forms > sit&C > Embed/Share ───
# The URL from the iframe embed code (secure.na1.adobesign.com/public/esignWidget?wid=...)
ACROBAT_SIGN_WEBFORM_URL=https://secure.na1.adobesign.com/public/esignWidget?wid=REPLACE_ME

# The wid= value from the URL above (used to query Sign API for latest agreement status)
ACROBAT_SIGN_WIDGET_ID=REPLACE_ME

# ─── Your EDS storefront origin (no trailing slash) ─────────────────────────
# Allows the checkout block to call this action cross-origin
ALLOWED_ORIGIN=https://main--sitime--YOUR-ORG.hlx.page

# ─── Acrobat Sign API — only needed for status polling via Sign REST API ─────
# Base URL matches your Sign account shard (na1, eu1, etc.)
ACROBAT_SIGN_API_BASE=https://api.na1.adobesign.com/api/rest/v6
# Generate a demo token in Acrobat Sign > Account > Personal Preferences > Access Tokens
ACROBAT_SIGN_ACCESS_TOKEN=REPLACE_ME
